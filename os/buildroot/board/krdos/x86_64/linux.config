# Minimal-ish x86_64 kernel config for QEMU bring-up with DRM + input.
# Not production-hardened; intended to boot the demo image and run Weston.

CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_EXPERT=y

CONFIG_BPF_SYSCALL=y
CONFIG_FHANDLE=y

CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

CONFIG_UNIX=y

CONFIG_VT=y
CONFIG_VT_CONSOLE=y

CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_VIRTIO_GPU=y

CONFIG_FB=y
CONFIG_FRAMEBUFFER_CONSOLE=y

CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y

CONFIG_HID=y
CONFIG_HID_GENERIC=y

CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_EHCI_HCD=y

CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_VIRTIO_NET=y

CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_VIRTIO_MMIO=y

CONFIG_EXT4_FS=y
CONFIG_EXT2_FS=y
CONFIG_MSDOS_FS=y
CONFIG_VFAT_FS=y

